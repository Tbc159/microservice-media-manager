# Variabili NON sensibili del dominio source in staging (= "dev" sull'host locale).
# I secret (API_KEY, STORAGE_ACCESS_KEY, STORAGE_SECRET_KEY) stanno nelle GitHub Environments.
APP_ENV=staging
LOG_LEVEL=info
REQUEST_TIMEOUT_SECONDS=30

# Persistenza: SQLite nel container, su volume montato.
SOURCE_DB_PATH=/data/source.db

# Storage: in dev solo upload locale su FS, nessun MinIO. stream_url sara' null.
STORAGE_BACKEND=local
SOURCE_MEDIA_DIR=/data/media
