# Variabili NON sensibili del dominio source in production.
# I secret (API_KEY, STORAGE_ACCESS_KEY, STORAGE_SECRET_KEY) stanno nelle GitHub Environments.
APP_ENV=production
LOG_LEVEL=warning
REQUEST_TIMEOUT_SECONDS=60

# Persistenza: SQLite nel container, su volume montato.
SOURCE_DB_PATH=/data/source.db

# Storage: stesso modello di collaudo (MinIO self-hosted, gestito dal team operations).
# Per migrare a S3/R2: STORAGE_ENDPOINT al provider + STORAGE_SECURE=true, codice invariato.
STORAGE_BACKEND=minio
STORAGE_ENDPOINT=minio:9000
STORAGE_BUCKET=media-source
STORAGE_SECURE=false
